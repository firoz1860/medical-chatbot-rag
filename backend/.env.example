# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-east-1

# PINECONE_INDEX accepts either:
#   Option A – a short index name (max 45 chars). The app will create it automatically.
#              Example: PINECONE_INDEX=medical-chatbot
#
#   Option B – the full host URL from your Pinecone dashboard → "Indexes > your index > Host".
#              The app will connect directly; no creation needed.
#              Example: PINECONE_INDEX=https://medical-chatbot-xxxx.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX=medical-chatbot

# Embedding Model (HuggingFace – free, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
